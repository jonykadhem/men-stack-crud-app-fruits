    <%- include('./partials/nav') %>

    <h1>Edit a Fruit</h1>
    <h3><%= foundFruit.name %></h3>
    <form action="/fruits/<%= foundFruit._id%>?_method=PUT " method="POST" class="new">
        <div>
            
            <label for="name">Name:</label>
            <input type="text" id="name" name="name" value="<%= foundFruit.name %>">
        </div>
        <br>
        <label for="category">Category:</label>

<select name="category" id="category" required>
    <option
        value="citrus"
        <%= foundFruit.category === 'citrus' ? 'selected' : '' %>
    >
        Citrus
    </option>

    <option
        value="berry"
        <%= foundFruit.category === 'berry' ? 'selected' : '' %>
    >
        Berry
    </option>

    <option
        value="tropical"
        <%= foundFruit.category === 'tropical' ? 'selected' : '' %>
    >
        Tropical
    </option>

    <option
        value="stone-fruit"
        <%= foundFruit.category === 'stone-fruit' ? 'selected' : '' %>
    >
        Stone Fruit
    </option>

    <option
        value="melon"
        <%= foundFruit.category === 'melon' ? 'selected' : '' %>
    >
        Melon
    </option>

    <option
        value="other"
        <%= foundFruit.category === 'other' ? 'selected' : '' %>
    >
        Other
    </option>
</select>
<br>
        
        <div class="checkbox-div">
            <label for="isReadyToEat">Is Ready To Eat?</label>
            <% if (foundFruit.isReadyToEat) { %>
                <input type="checkbox" id="isReadyToEat" name="isReadyToEat" checked>
                
            <% }else{ %>
                    
                <input type="checkbox" id="isReadyToEat" name="isReadyToEat">
            <% } %>
        </div>
<br>
        <button type="submit">Edit Fruit</button>

    </form>
</body>
</html>